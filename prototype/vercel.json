{
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/assets/(.*)", "dest": "api/index.js" },
    { "src": "/css/(.*)", "dest": "api/index.js" },
    { "src": "/js/(.*)", "dest": "api/index.js" },
    { "src": "/videos/(.*)", "dest": "api/index.js" },
    { "src": "/admin/(.*)", "dest": "api/index.js" },
    { "src": "/favicon.svg", "dest": "api/index.js" },
    { "src": "/(.*)", "dest": "api/index.js" }
  ]
}
