# ── Database ──
# Required: Postgres connection string for the application database.
# Local dev (docker-compose): postgresql://demy:demy_dev@localhost:5432/demy_store
# Production (Supabase/Neon): use the pooled connection string on port 6543
DATABASE_URL=postgresql://demy:demy_dev@localhost:5432/demy_store

# ── Authentication ──
# Required: Secret key used to sign and verify JWT tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Server ──
# Optional: Port for the local dev server. Defaults to 3003.
PORT=3003

# ── Vercel ──
# Optional: Set automatically by Vercel when deployed. Detected at runtime to
# adjust file paths (upload dir → /tmp) and skip local DB init / listener.
# Do not set this manually.
# VERCEL=1

# ── Analytics ──
# Optional: Endpoint URL for the analytics service.
# ANALYTICS_ENDPOINT=https://analytics.example.com/api/events
